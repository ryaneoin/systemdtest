# ── Identity ──────────────────────────────────────────────────────────────────
NM2_ENV=dev
NM2_HOSTNAME=nm2-ingest-dev
NM2_USER=nm2
NM2_BASE=/home/nm2

# ── vmagent ───────────────────────────────────────────────────────────────────
# Receives remote_write from Telegraf; fans out to both Azure regions.
VMAGENT_HTTP_LISTEN_ADDR=0.0.0.0:8429
VMAGENT_REMOTE_WRITE_URL_1=https://vminsert-dev.azure-central.example.com/api/v1/write
VMAGENT_REMOTE_WRITE_URL_2=https://vminsert-dev.azure-east.example.com/api/v1/write
VMAGENT_CACHE_PATH=/home/nm2/data/vmagent-cache
VMAGENT_MAX_DISK_PER_URL=512mb
VMAGENT_MEMORY_PERCENT=40
VMAGENT_LOG_LEVEL=INFO

# ── Telegraf ──────────────────────────────────────────────────────────────────
TELEGRAF_HOSTNAME=nm2-ingest-dev
TELEGRAF_AGENT_INTERVAL=10s
TELEGRAF_AGENT_FLUSH_INTERVAL=10s
TELEGRAF_AGENT_METRIC_BATCH=1000
TELEGRAF_AGENT_METRIC_BUFFER=10000
# Telegraf ships metrics into local vmagent
TELEGRAF_REMOTE_WRITE_URL=http://127.0.0.1:8429/api/v1/write
# Telegraf ships logs into local Loki
TELEGRAF_LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_LISTEN_ADDR=0.0.0.0:9090
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_TSDB_PATH=/home/nm2/data/prometheus
PROMETHEUS_LOG_LEVEL=info

# ── Loki ──────────────────────────────────────────────────────────────────────
LOKI_HTTP_LISTEN_PORT=3100
LOKI_GRPC_LISTEN_PORT=9096
LOKI_STORAGE_PATH=/home/nm2/data/loki
LOKI_LOG_LEVEL=info
LOKI_RETENTION_PERIOD=72h
