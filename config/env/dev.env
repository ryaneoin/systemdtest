# ── Identity ──────────────────────────────────────────────────────────────────
NM2_ENV=dev
NM2_HOSTNAME=nm2-ingest-dev
NM2_USER=nm2
NM2_BASE=/home/nm2

# ── Service ports (internal) ─────────────────────────────────────────────────
# These drive listen addrs and inter-service URLs below — change here only.
VMAGENT_PORT=8429
PROMETHEUS_PORT=9090
LOKI_HTTP_PORT=3100
LOKI_GRPC_PORT=9096
TELEGRAF_METRICS_PORT=9273

# ── Telemetry input ports (FW range 9000-9020, TCP+UDP) ──────────────────────
TELEGRAF_PORT_IPFIX=9000        # UDP  IPFIX / NetFlow v9 v10
TELEGRAF_PORT_SYSLOG_UDP=9001   # UDP  Syslog RFC 5424
TELEGRAF_PORT_SYSLOG_TCP=9002   # TCP  Syslog RFC 5424 (reliable)
TELEGRAF_PORT_SNMP_TRAP=9003    # UDP  SNMP Trap v1/v2c/v3
TELEGRAF_PORT_MDT=9004          # TCP  Cisco MDT gRPC dial-out

# ── vmagent ───────────────────────────────────────────────────────────────────
VMAGENT_HTTP_LISTEN_ADDR=0.0.0.0:${VMAGENT_PORT}
VMAGENT_REMOTE_WRITE_URL_1=https://vminsert-dev.azure-central.example.com/api/v1/write
VMAGENT_REMOTE_WRITE_URL_2=https://vminsert-dev.azure-east.example.com/api/v1/write
VMAGENT_CACHE_PATH=/home/nm2/data/vmagent-cache
VMAGENT_MAX_DISK_PER_URL=512mb
VMAGENT_MEMORY_PERCENT=40
VMAGENT_LOG_LEVEL=INFO

# ── Telegraf ──────────────────────────────────────────────────────────────────
TELEGRAF_HOSTNAME=nm2-ingest-dev
TELEGRAF_AGENT_INTERVAL=10s
TELEGRAF_AGENT_FLUSH_INTERVAL=10s
TELEGRAF_AGENT_METRIC_BATCH=1000
TELEGRAF_AGENT_METRIC_BUFFER=10000
TELEGRAF_REMOTE_WRITE_URL=http://127.0.0.1:${VMAGENT_PORT}/api/v1/write
TELEGRAF_LOKI_URL=http://127.0.0.1:${LOKI_HTTP_PORT}/loki/api/v1/push

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_LISTEN_ADDR=0.0.0.0:${PROMETHEUS_PORT}
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_TSDB_PATH=/home/nm2/data/prometheus
PROMETHEUS_LOG_LEVEL=info

# ── Loki ──────────────────────────────────────────────────────────────────────
LOKI_HTTP_LISTEN_PORT=${LOKI_HTTP_PORT}
LOKI_GRPC_LISTEN_PORT=${LOKI_GRPC_PORT}
LOKI_STORAGE_PATH=/home/nm2/data/loki
LOKI_LOG_LEVEL=info
LOKI_RETENTION_PERIOD=72h
