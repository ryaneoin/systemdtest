# ── nm2-ingest .gitignore ─────────────────────────────────────────────────────
# The repo contains only templates and source configs.
# Generated/rendered files and binaries never go into git.

# Rendered outputs (generated by install.sh — live on the host, not in git)
*.toml
*.yaml
run.sh
*.service
!*.service.tmpl
!*.target

# Binaries and version sidecars
bin/
*.version

# Data directories
data/
logs/

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/
