# ── Telegraf inputs ───────────────────────────────────────────────────────────
# Generated from inputs.toml.tmpl by install.sh — edit the template, not this file.
#
# Section 1: Host observability  — metrics about the nm2-ingest VM itself
# Section 2: Telemetry ingestion — the network data this host exists to receive
#             Ports driven by TELEGRAF_PORT_* vars in config/env/<ENV>.env

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 1 — Host observability
# ══════════════════════════════════════════════════════════════════════════════

# ── CPU ───────────────────────────────────────────────────────────────────────
[[inputs.cpu]]
  percpu           = true
  totalcpu         = true
  collect_cpu_time = false
  report_active    = false
  core_tags        = false

# ── Memory ────────────────────────────────────────────────────────────────────
[[inputs.mem]]

# ── Disk usage ────────────────────────────────────────────────────────────────
[[inputs.disk]]
  ignore_fs = ["tmpfs", "devtmpfs", "devfs", "iso9660", "overlay", "aufs", "squashfs"]

# ── Disk I/O ──────────────────────────────────────────────────────────────────
[[inputs.diskio]]

# ── Network ───────────────────────────────────────────────────────────────────
[[inputs.net]]
  ignore_protocol_stats = true

# ── System load / uptime ──────────────────────────────────────────────────────
[[inputs.system]]

# ── Processes ─────────────────────────────────────────────────────────────────
[[inputs.processes]]

# ── Telegraf internal self-monitoring ─────────────────────────────────────────
[[inputs.internal]]
  collect_memstats = true

# ── Systemd unit health ────────────────────────────────────────────────────────
[[inputs.systemd_units]]
  unit_filter = ["nm2-telegraf.service", "nm2-vmagent.service", "nm2-prometheus.service", "nm2-loki.service"]

# ── Journal logs (ships to Loki via outputs.toml) ─────────────────────────────
[[inputs.journald]]
  [inputs.journald.tags]
    host = "${TELEGRAF_HOSTNAME}"
    env  = "${NM2_ENV}"


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 2 — Telemetry ingestion
# Ports: see TELEGRAF_PORT_* in config/env/<ENV>.env  (FW range 9000-9020)
# ══════════════════════════════════════════════════════════════════════════════

# ── IPFIX / NetFlow v9 v10 ────────────────────────────────────────────────────
# UDP ${TELEGRAF_PORT_IPFIX} — accepts IPFIX (v10) and NetFlow v9 from network devices.
[[inputs.netflow]]
  service_address = "udp://:${TELEGRAF_PORT_IPFIX}"
  [inputs.netflow.tags]
    env    = "${NM2_ENV}"
    source = "netflow"

# ── Syslog (raw UDP stream) ───────────────────────────────────────────────────
# UDP ${TELEGRAF_PORT_SYSLOG} — raw UDP socket listener; proven to work where
# inputs.syslog framing causes issues. Captures each datagram as a string.
[[inputs.socket_listener]]
  service_address  = "udp://:${TELEGRAF_PORT_SYSLOG}"
  name_override    = "syslog"
  data_format      = "value"
  data_type        = "string"
  read_buffer_size = "64KiB"
  [inputs.socket_listener.tags]
    env    = "${NM2_ENV}"
    source = "syslog"

# ── SNMP Trap ─────────────────────────────────────────────────────────────────
# UDP ${TELEGRAF_PORT_SNMP_TRAP} — receives SNMPv1, v2c, and v3 traps.
# Add community strings / v3 auth config below once known.
[[inputs.snmp_trap]]
  service_address = "udp://:${TELEGRAF_PORT_SNMP_TRAP}"
  [inputs.snmp_trap.tags]
    env    = "${NM2_ENV}"
    source = "snmp_trap"

# ── Cisco MDT — gRPC dial-out ─────────────────────────────────────────────────
# TCP ${TELEGRAF_PORT_MDT} — IOS-XR and IOS-XE gRPC dial-out (native + kvgpb encoding).
[[inputs.cisco_telemetry_mdt]]
  transport       = "grpc"
  service_address = ":${TELEGRAF_PORT_MDT}"
  [inputs.cisco_telemetry_mdt.tags]
    env    = "${NM2_ENV}"
    source = "mdt"
